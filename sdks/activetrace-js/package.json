{
  "name": "@activetrace/client",
  "version": "0.1.0",
  "description": "Active Trace SDK — observability and analytics for AI applications",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts"
  },
  "dependencies": {
    "@langfuse/client": "^4"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  }
}
